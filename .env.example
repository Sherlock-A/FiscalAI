# FiscalAI — Local Development Environment
# Copy this to .env and fill in values. Never commit .env to git.

# PostgreSQL
POSTGRES_USER=fiscalai
POSTGRES_PASSWORD=fiscalai_dev_secret
POSTGRES_DB=fiscalai

# Redis
REDIS_PASSWORD=redis_dev_secret

# App secret (must be >= 32 chars, random in production)
SECRET_KEY=dev_secret_change_in_prod_32chars!!

# External APIs (optional for MVP)
COPERNICUS_USER=
COPERNICUS_PASSWORD=

# AWS (only needed for S3 document storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
S3_BUCKET_DOCUMENTS=
